# ==============================================
# 1. 通用系统文件（所有环境通用）
# ==============================================
.DS_Store          # Mac 系统文件
Thumbs.db          # Windows 缩略图缓存
*.swp              # Vim 临时文件
*.swo              # Vim 临时文件
*~                 # 各种编辑器备份文件

# ==============================================
# 2. C/C++ 相关
# ==============================================
# 编译产物
*.obj
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.out
*.elf

# 构建目录
build/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
Makefile
cmake_install.cmake

# 预编译头
*.pch
*.gch

# ==============================================
# 3. Python 相关
# ==============================================
# 字节码
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境
venv/
.venv/
env/
.env/

# 测试/工具缓存
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# ==============================================
# 4. Java 相关
# ==============================================
# 编译产物
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Maven/Gradle
target/
.gradle/
build/
.mvn/wrapper/maven-wrapper.jar

